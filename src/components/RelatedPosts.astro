---
interface Post {
  slug: string;
  title: string;
  desc: string;
  category: string;
  date: string;
  readTime: string;
}
interface Props {
  posts: Post[];
}
const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="related-posts">
      <>
        <header>
          <>
            <p class="eyebrow">KEEP READING</p>
            <h2>관련 글</h2>
          </>
        </header>
        <div class="related-grid">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}/`}>
              <span>
                {post.category} · {post.readTime}
              </span>
              <h3>{post.title}</h3>
              <p>{post.desc}</p>
              <b>읽어보기 →</b>
            </a>
          ))}
        </div>
      </>
    </section>
  )
}
