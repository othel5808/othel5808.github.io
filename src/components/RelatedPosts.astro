---
import type { CollectionEntry } from 'astro:content';
import { getBlogIdentity, getCategoryName, getPostPath } from '../lib/blog.mjs';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;
---

{
  posts.length > 0 && (
    <section class="related-posts">
      <>
        <header>
          <>
            <p class="eyebrow">KEEP READING</p>
            <h2>관련 글</h2>
          </>
        </header>
        <div class="related-grid">
          {posts.map((post) => (
            <a href={getPostPath(post)}>
              <span>
                {getCategoryName(getBlogIdentity(post).category)} · {post.data.readTime}
              </span>
              <h3>{post.data.title}</h3>
              <p>{post.data.desc}</p>
              <b>읽어보기 →</b>
            </a>
          ))}
        </div>
      </>
    </section>
  )
}
